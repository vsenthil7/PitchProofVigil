# PitchProof Vigil — environment configuration
# Copy to .env and fill in. Anything left blank falls back to a mock.

# ---- Global switch -------------------------------------------------------
# true  = run everything on mocks (no external calls) — default
# false = use real services where credentials are present
USE_MOCKS=true

# ---- Google Cloud / Gemini (hard requirement for real agent) -------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_MODEL=gemini-2.0-flash
# Optional Vertex AI Agent Builder app
AGENT_BUILDER_APP_ID=

# ---- Arize Phoenix (hard requirement for real tracing; free via Docker) --
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_API_KEY=

# ---- Arize AX (optional, production online evals) ------------------------
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# ---- Eval gate -----------------------------------------------------------
# Minimum aggregate score (0-1) required to pass the promotion gate.
REGRESSION_THRESHOLD=0.85

# Encryption at rest (comma-separated Fernet keys, newest first).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in dev (a key is derived from JWT_SECRET; NOT for production).
ENCRYPTION_KEYS=

# Rate limiting (per authenticated identity).
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_PER_SECOND=10

# Webhook SSRF guard. In production keep these defaults (https only, DNS
# resolution on so internal/private targets are blocked).
WEBHOOK_ALLOW_HTTP=false
WEBHOOK_RESOLVE_DNS=true
